<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.addressbook.ui.MainController">
    <!-- 顶部工具栏 -->
    <top>
        <ToolBar>
            <Button text="新建联系人" onAction="#onAddContact" />
            <Button text="编辑" onAction="#onEditContact" />
            <Button text="删除" onAction="#onDeleteContact" />
            <Button text="导入/导出" onAction="#onImportExport" />
            <Label text="    搜索:" />
            <TextField fx:id="searchField" promptText="输入姓名/手机/拼音检索" prefWidth="200" />
        </ToolBar>
    </top>

    <!-- 中间主体：左右分割面板 -->
    <center>
        <SplitPane dividerPositions="0.25">
            <!-- 左侧：分组树 -->
            <TreeView fx:id="groupTreeView" />
            
            <!-- 右侧：联系人列表 -->
            <TableView fx:id="contactTableView">
                <columns>
                    <TableColumn fx:id="nameColumn" text="姓名" prefWidth="150" />
                    <TableColumn fx:id="mobileColumn" text="手机号码" prefWidth="200" />
                    <TableColumn fx:id="emailColumn" text="电子邮件" prefWidth="200" />
                    <TableColumn fx:id="groupColumn" text="所在分组" prefWidth="150" />
                </columns>
                <!-- 确保列占满剩余空间 (JDK14+推荐使用，旧版可行也可行) -->
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </SplitPane>
    </center>
    
    <!-- 底部状态栏 -->
    <bottom>
        <HBox>
            <padding>
                <Insets top="5" right="5" bottom="5" left="5"/>
            </padding>
            <Label text="总计: 4 个联系人" />
        </HBox>
    </bottom>
</BorderPane>
