<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.control.TreeView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>

<BorderPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.addressbook.ui.MainController" stylesheets="@style.css">
    <!-- 顶部工具栏 -->
    <top>
        <ToolBar>
            <Button text="新建联系人" onAction="#onAddContact" />
            <Button text="删除" onAction="#onDeleteContact" />
            <Button text="导入" onAction="#onImport" />
            <Button text="导出" onAction="#onExport" />
            <Label text="    搜索:" />
            <TextField fx:id="searchField" promptText="输入姓名/手机/拼音检索" prefWidth="200" />
        </ToolBar>
    </top>

    <!-- 中间主体：左右分割面板 -->
    <center>
        <SplitPane dividerPositions="0.25">
            <!-- 左侧：分组树 -->
            <TreeView fx:id="groupTreeView" />
            
            <!-- 右侧：联系人列表 (卡片流) -->
            <ListView fx:id="contactListView" styleClass="contact-list-view" />
        </SplitPane>
    </center>
    
    <!-- 底部状态栏 -->
    <bottom>
        <HBox>
            <padding>
                <Insets top="5" right="5" bottom="5" left="5"/>
            </padding>
            <Label text="总计: 4 个联系人" />
        </HBox>
    </bottom>
</BorderPane>
